{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.nis2compass.eu/schemas/nis2-control.schema.json",
  "title": "NIS2COMPASS Control",
  "type": "object",
  "required": ["control_id", "control_area", "plain_requirement"],
  "properties": {
    "control_id": { "type": "string" },
    "control_area": { "type": "string" },
    "plain_requirement": { "type": "string" },
    "evidence_needed": { "type": "string" },
    "owner": { "type": "string" },
    "status": { "enum": ["planned", "in-progress", "reviewed", "approved", "not-applicable"] }
  }
}
