---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getNews } from "../lib/docs.mjs";

const news = await getNews();
const isExternal = (href) => href.startsWith("https://");
---
<BaseLayout title="NIS2COMPASS | Public NIS2 Readiness Knowledge Hub" mainClass="home-main">
  <div class="home-dashboard">
    <section class="home-intro" aria-labelledby="home-title">
      <div class="home-title-row">
        <img src="/logo.svg" alt="" aria-hidden="true" width="76" height="76" />
        <div>
          <p class="eyebrow">Public dissemination hub</p>
          <h1 id="home-title">NIS2COMPASS</h1>
        </div>
      </div>
      <p class="home-lead">Learn how to organize NIS2 readiness work, connect cybersecurity activity to reviewable evidence, and understand the six CYberSynchrony modules without exposing private pilot information.</p>
      <div class="actions home-actions">
        <a class="button" href="/docs/">Open the knowledge base</a>
        <a class="button secondary" href="/docs/project-overview/">Project overview</a>
      </div>
    </section>

    <section class="home-news" aria-labelledby="latest-news-heading">
      <div class="home-section-heading">
        <div>
          <p class="eyebrow">Public register</p>
          <h2 id="latest-news-heading">Latest News</h2>
        </div>
        <a href="/news/">View all</a>
      </div>
      <ol>
        {news.items.slice(0, 4).map((item) => (
          <li>
            <time datetime={item.date}>{item.date_label}</time>
            <a href={item.href} rel={isExternal(item.href) ? "external" : undefined}>{item.title}</a>
          </li>
        ))}
      </ol>
    </section>

    <nav class="home-shortcuts" aria-label="Explore NIS2COMPASS">
      <a href="/docs/cybersynchrony-alignment/"><strong>6 CYberSynchrony modules</strong><span>Roles, public results, and relationships</span></a>
      <a href="/tools/"><strong>Public tools</strong><span>Sourced upstream software references</span></a>
      <a href="/docs/progress/"><strong>Project progress</strong><span>Sanitized monthly updates</span></a>
      <a href="/blogs/"><strong>Partner articles</strong><span>SmartClover and AI STM perspectives</span></a>
    </nav>

    <aside class="position-box home-position" aria-label="Public software and disclosure position">
      <strong>Public software and disclosure position</strong>
      <p>CYberSynchrony results and software links are public research references. A listing does not claim NIS2COMPASS selection, deployment, integration, pilot completion, or authorization to test a live system. Private pilot data, vulnerabilities, credentials, and funder records are not published here.</p>
    </aside>
  </div>
</BaseLayout>
